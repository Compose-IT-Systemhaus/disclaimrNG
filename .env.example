# --- Django ----------------------------------------------------------------
# Generate a strong key for production: python -c 'import secrets; print(secrets.token_urlsafe(64))'
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_LOG_LEVEL=INFO
DJANGO_TIME_ZONE=Europe/Berlin
DJANGO_LANGUAGE_CODE=en-us

# --- PostgreSQL ------------------------------------------------------------
# Used by the postgres service in compose.yml *and* parsed by Django.
POSTGRES_DB=disclaimr
POSTGRES_USER=disclaimr
POSTGRES_PASSWORD=change-me

# Connection string for the Django side. Hostname must be the compose service name.
DATABASE_URL=postgres://disclaimr:change-me@db:5432/disclaimr

# --- Milter ---------------------------------------------------------------
# Address the milter daemon binds to. Set to 0.0.0.0 inside the container so
# Postfix on the host (or another container) can reach it on port 5000.
MILTER_SOCKET=inet:0.0.0.0:5000

# --- Media uploads --------------------------------------------------------
# Inline images (logos, signatures) live under this URL prefix. Mails
# rendered by the milter use MEDIA_BASE_URL + the file path so recipients
# can load them — point this at the public hostname of your disclaimrNG
# install (e.g. https://signatures.example.com). Falls back to MEDIA_URL
# (relative) when unset, which is fine for local dev but not for real mail.
MEDIA_BASE_URL=

# Where uploaded images live on the host. Defaults to a Docker named volume
# (managed by compose). Set this to a host path (e.g. /srv/disclaimrng/media)
# if you want to back the directory up with rsync or mount it from a NAS.
# MEDIA_HOST_PATH=

# --- Tenants (multi-mandant) ---------------------------------------------
# Optional: declare tenants declaratively. A tenant bundles one or more
# sender domains with an LDAP server — the milter looks up the tenant by
# the sender's domain and uses its directory servers when an action has
# none of its own. Leave TENANTS empty to manage everything via the admin.
#
# Set TENANT_SYNC_PRUNE=1 to delete env-managed tenants that no longer
# appear in TENANTS (manually-created tenants are never touched).
#
# TENANTS=acme,globex
# TENANT_SYNC_PRUNE=
#
# Per-handle vars (replace <HANDLE> with the uppercased handle):
#   TENANT_<HANDLE>_NAME           Display name (default: handle)
#   TENANT_<HANDLE>_DESCRIPTION    Free-form description
#   TENANT_<HANDLE>_DOMAINS        required, comma-separated sender domains
#   TENANT_<HANDLE>_ENABLED        true | false (default: true)
#
# Example for two tenants:
# TENANTS=acme,globex
# TENANT_ACME_NAME=Acme Corp
# TENANT_ACME_DOMAINS=acme.com,acme.de
# TENANT_GLOBEX_NAME=Globex
# TENANT_GLOBEX_DOMAINS=globex.com

# --- LDAP / Active Directory ---------------------------------------------
# Optional: define directory servers declaratively. The entrypoint runs
# ``manage.py sync_directory_servers`` on boot, which upserts one
# DirectoryServer row per handle in LDAP_SERVERS. Leave LDAP_SERVERS empty
# to manage everything via the admin UI instead.
#
# Set LDAP_SYNC_PRUNE=1 to delete env-managed rows that no longer appear in
# LDAP_SERVERS (manually-created rows are never touched).
#
# LDAP_SERVERS=primary,backup
# LDAP_SYNC_PRUNE=
#
# Per-handle vars (replace <HANDLE> with the uppercased handle):
#   LDAP_SERVER_<HANDLE>_NAME              Display name (default: handle)
#   LDAP_SERVER_<HANDLE>_DESCRIPTION       Free-form description
#   LDAP_SERVER_<HANDLE>_FLAVOR            ldap | ad | custom (default: ldap)
#   LDAP_SERVER_<HANDLE>_BASE_DN           required, e.g. dc=example,dc=com
#   LDAP_SERVER_<HANDLE>_URL               required, comma-separated for failover
#   LDAP_SERVER_<HANDLE>_BIND_DN           empty = anonymous bind
#   LDAP_SERVER_<HANDLE>_BIND_PASSWORD
#   LDAP_SERVER_<HANDLE>_SEARCH_QUERY      default: derived from FLAVOR
#   LDAP_SERVER_<HANDLE>_SEARCH_ATTRIBUTES default: derived from FLAVOR
#   LDAP_SERVER_<HANDLE>_ENABLE_CACHE      true | false (default: true)
#   LDAP_SERVER_<HANDLE>_CACHE_TIMEOUT     seconds (default: 3600)
#   LDAP_SERVER_<HANDLE>_ENABLED           true | false (default: true)
#   LDAP_SERVER_<HANDLE>_TENANT            tenant slug — links this server
#                                          to the tenant declared above
#
# Example: an Acme AD wired to the Acme tenant:
# LDAP_SERVERS=acme_ad
# LDAP_SERVER_ACME_AD_FLAVOR=ad
# LDAP_SERVER_ACME_AD_BASE_DN=dc=acme,dc=com
# LDAP_SERVER_ACME_AD_URL=ldaps://dc1.acme.com,ldaps://dc2.acme.com
# LDAP_SERVER_ACME_AD_BIND_DN=CN=disclaimr,OU=Service,DC=acme,DC=com
# LDAP_SERVER_ACME_AD_BIND_PASSWORD=change-me
# LDAP_SERVER_ACME_AD_TENANT=acme
