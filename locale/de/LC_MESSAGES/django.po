# --- Signaturtest pipeline messages --------------------------------------
msgid ""
"The sender IP did not match any requirement — the milter pipeline would "
"pass this mail through unchanged."
msgstr ""
"Die Absender-IP traf auf keine Requirement zu — die Milter-Pipeline würde "
"diese Mail unverändert durchlassen."

msgid ""
"No active rule matched this mail — the pipeline would pass it through "
"unchanged."
msgstr ""
"Die Mail traf auf keine aktive Regel — die Pipeline würde sie unverändert "
"durchlassen."

msgid ""
"A configured Requirement contains an invalid regex pattern: %(error)s. "
"Please fix the pattern in the Requirement's Sender / Recipient / Header / "
"Body field — a common mistake is a bare ``*`` where you meant ``.*``."
msgstr ""
"Eine konfigurierte Requirement enthält ein ungültiges Regex-Muster: "
"%(error)s. Bitte das Regex-Feld der betroffenen Requirement (Sender / "
"Empfänger / Header / Body) korrigieren — typischer Fehler: ein nacktes "
"``*`` statt ``.*``."

msgid ""
"The pipeline modified the mail but no rule could be attributed "
"unambiguously."
msgstr ""
"Die Pipeline hat die Mail verändert, aber keine Regel konnte eindeutig "
"zugeordnet werden."

msgid "%(count)d rule matched — the mail would be modified as shown below."
msgid_plural ""
"%(count)d rules matched — the mail would be modified as shown below."
msgstr[0] ""
"%(count)d Regel hat gegriffen — die Mail würde wie unten gezeigt verändert "
"werden."
msgstr[1] ""
"%(count)d Regeln haben gegriffen — die Mail würde wie unten gezeigt "
"verändert werden."
